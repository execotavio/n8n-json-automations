    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst resultado = [];\n\nfor (const item of items) {\n  const xml = item.json.data;\n  const categoria = item.json.categoria || 'geral';\n\n  // Extrai itens do RSS com regex simples\n  const itemRegex = /<item>([\\s\\S]*?)<\\/item>/g;\n  let match;\n\n  while ((match = itemRegex.exec(xml)) !== null) {\n    const bloco = match[1];\n\n    const titulo = (bloco.match(/<title><!\\[CDATA\\[(.*?)\\]\\]><\\/title>/) || bloco.match(/<title>(.*?)<\\/title>/))?.[1] || '';\n    const link = (bloco.match(/<link>(.*?)<\\/link>/) || [])[1] || '';\n    const descricao = (bloco.match(/<description><!\\[CDATA\\[(.*?)\\]\\]><\\/description>/) || bloco.match(/<description>(.*?)<\\/description>/))?.[1] || '';\n    const pubDate = (bloco.match(/<pubDate>(.*?)<\\/pubDate>/) || [])[1] || '';\n\n    if (!link) continue;\n\n    resultado.push({\n      json: {\n        titulo: titulo.trim(),\n        link: link.trim(),\n        descricao: descricao.trim(),\n        pubDate: pubDate.trim(),\n        categoria\n      }\n    });\n  }\n}\n\nreturn resultado;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
