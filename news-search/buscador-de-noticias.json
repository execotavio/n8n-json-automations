    {
      "parameters": {
        "jsCode": "let rawContent = $input.first().json.choices[0].message.content;\nrawContent = rawContent.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst classificacao = JSON.parse(rawContent);\n\nconst noticiasOriginais = $('Montar JSON para LLM').first().json._noticias;\n\nconst LIMITE = 10;\nconst contadores = { esportes: 0, musica: 0, filmes_series: 0, games: 0 };\nconst resultado = [];\n\nfor (const item of classificacao) {\n  if (item.categoria === 'descartar') continue;\n  if (contadores[item.categoria] >= LIMITE) continue;\n\n  const noticia = noticiasOriginais.find(n => n.id === item.id);\n  if (!noticia) continue;\n\n  resultado.push({ ...noticia, categoria: item.categoria });\n  contadores[item.categoria]++;\n}\n\nreturn resultado.map(n => ({ json: n }));"
      },
