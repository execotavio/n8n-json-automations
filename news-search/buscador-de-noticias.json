    {
      "parameters": {
        "jsCode": "const { titulos, noticias } = $input.first().json;\n\nreturn {\n  json: {\n    model: \"gpt-4o-mini\",\n    messages: [\n      {\n        role: \"system\",\n        content: \"Você é um classificador de notícias brasileiras. Classifique cada título em uma das categorias: se esportes a categoria é 9 , se musica a categoria é 5, se filmes_series a categoria é 2, se games a categoria é 6 ou descartar. \\n\\nRegras:\\n- esportes: futebol, F1, tênis, vôlei, basquete, campeonatos esportivos\\n- musica: artistas, shows, álbuns, indústria musical\\n- filmes_series: streaming, cinema, séries, premiações\\n- games: videogames, consoles, e-sports\\n- descartar: política, economia, notícias locais, celebridades sem relevância\\n\\nRetorne APENAS um JSON válido no formato:\\n[{\\\"id\\\": 0, \\\"categoria\\\": \\\"esportes\\\"}]\"\n      },\n      {\n        role: \"user\",\n        content: JSON.stringify(titulos)\n      }\n    ],\n    _noticias: noticias\n  }\n};"
      },
