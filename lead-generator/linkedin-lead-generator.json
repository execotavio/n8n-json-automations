    {
      "parameters": {
        "jsCode": "const listaCompleta = $('Lista unificada de pessoas').first().json.lista_completa;\nconst empresas_alvo = $input.first().json.empresas;\n\nconst pessoas = listaCompleta.map((item, idx) => {\n  const data = item.data || {};\n  const experiences = data.experiences || [];\n  \n  // Pega a experiência atual\n  const expAtual = experiences.find(e => e.is_current === true);\n  \n  return {\n    id: idx,\n    nome: data.full_name || data.first_name || '',\n    empresa_atual: expAtual?.company || '',\n    cargo_atual: expAtual?.title || '',\n    url_perfil_linkedin: data.linkedin_url || ''\n  };\n});\n\nconst system = `Você é um validador de dados B2B. Confirme se a empresa_atual da pessoa está na lista de empresas_alvo. Seja rigoroso.`;\n\nconst user = `\nDADOS:\n${JSON.stringify({ empresas_alvo, pessoas })}\n\nRetorne APENAS JSON puro:\n{\n  \"aprovados\": [{ \"id\": number, \"nome\": string, \"empresa_atual\": string, \"empresa_match\": string }],\n  \"rejeitados\": [{ \"id\": number, \"motivo\": string }]\n}\n`.trim();\n\nreturn {\n  json: {\n    payload: {\n      model: \"route-llm\",\n      temperature: 0.1,\n      messages: [\n        { role: \"system\", content: system },\n        { role: \"user\", content: user }\n      ]\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2272,
        -816
      ],
      "id": "e1bbfefb-60e6-4c7a-824e-6f44707ab9f4",
      "name": "Prompt [Check de empresas]"
    },
    {
      "parameters": {
        "jsCode": "// Pega a resposta da IA\nconst content = $input.first().json.choices[0].message.content;\n\n// Remove markdown se vier com ```json\nconst cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst resultado = JSON.parse(cleaned);\n\n// Pega a lista completa de pessoas do nó anterior\nconst listaCompleta = $('Lista unificada de pessoas').first().json.lista_completa;\n\n// Para cada aprovado, busca os dados completos do perfil\nconst aprovados = resultado.aprovados.map(aprovado => {\n  const perfil = listaCompleta[aprovado.id];\n  const data = perfil?.data || {};\n  \n  return {\n    json: {\n      nome: data.full_name || data.first_name || aprovado.nome || '',\n      cargo: aprovado.cargo_atual || data.headline || '',\n      email: data.email || '',\n      telefone: data.phone || '',\n      empresa: aprovado.empresa_match || '',\n      sobre_empresa: data.company_description || '', \n      url_empresa: data.company_linkedin_url || '',\n      url_perfil_linkedin: data.linkedin_url || aprovado.url_perfil_linkedin || ''\n    }\n  };\n});\n\nreturn aprovados;"
      },
