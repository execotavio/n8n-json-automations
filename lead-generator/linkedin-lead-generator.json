    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Pega a resposta bruta da Abacus\nconst response = $input.item.json.choices[0].message.content;\n\ntry {\n  // 2. Tenta encontrar o JSON dentro da resposta (caso a IA mande texto antes ou depois)\n  const jsonMatch = response.match(/\\{[\\s\\S]*\\}/);\n  const cleanJson = jsonMatch ? jsonMatch[0] : response;\n  \n  // 3. Transforma o texto em objeto JavaScript\n  const parsedData = JSON.parse(cleanJson);\n\n  // 4. Retorna o objeto pronto para o n8n usar como colunas\n  return {\n    json: parsedData\n  };\n} catch (error) {\n  // Caso a IA não retorne um JSON válido, retorna o erro e o texto original para debug\n  return {\n    json: {\n      error: \"Falha ao parsear JSON da IA\",\n      raw_response: response\n    }\n  };\n}"
      },
